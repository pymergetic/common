@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(easybind CONFIG REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/pymergetic_commonTargets.cmake")

# Also export the helper macro for consumers using find_package(pymergetic_common).
function(pymergetic_add_extension target_name)
    easybind_add_extension(${target_name} ${ARGN})
    target_link_libraries(${target_name} PRIVATE pymergetic::common_interface)
endfunction()


